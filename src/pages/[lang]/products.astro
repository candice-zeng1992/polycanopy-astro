---
import Header from '../../components/Header';
import ProductsHero from '../../components/products/ProductsHero';
import ProductGrid from '../../components/products/ProductGrid'; 
import ProductSpecs from '../../components/products/ProductSpecs';
import MaterialIntro from '../../components/products/MaterialIntro'; 
import ProductAnalysis from '../../components/products/ProductAnalysis';
import ProductFeatures from '../../components/products/ProductFeatures';
import PremiumMaterials from '../../components/products/PremiumMaterials';
import ChooseUs from '../../components/products/ChooseUs';
import Footer from '../../components/Footer';
import { getProductDictionary } from '../../i18n';
import { getPostsByLang } from '../../utils/blogLoader'; // 路径分家引入，彻底消除 getPostsByLang 红线

import enDict from '../../i18n/en.json';
import zhDict from '../../i18n/zh.json';
import arDict from '../../i18n/ar.json';
import deDict from '../../i18n/de.json';
import esDict from '../../i18n/es.json';
import ptDict from '../../i18n/pt.json';
import frDict from '../../i18n/fr.json';
import ruDict from '../../i18n/ru.json';
import jaDict from '../../i18n/ja.json';
import itDict from '../../i18n/it.json';
import koDict from '../../i18n/ko.json';

// 🌟 核心修复：100% 正确且干净的 Astro 标准静态多语言路由语法
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'ar' } },
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ru' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'it' } },
    { params: { lang: 'ko' } },
  ];
}

const { lang } = Astro.params;

// 类型高能解耦：换用宽松通用的 Record 字典，彻底拍平红线
const dictionaries: Record<string, any> = {
  en: enDict,
  zh: zhDict,
  ar: arDict,
de: deDict,
  es: esDict,
  pt: ptDict,
  fr: frDict,
  ru: ruDict,
  ja: jaDict,
  it: itDict,
  ko: koDict,
};

// 类型安全闭环：通过强力类型断言，告诉 TS 读取绝对安全，彻底消灭这里的红线
const currentDict = dictionaries[lang as 'en' | 'zh' | 'ar' | 'de' | 'es' | 'pt' | 'fr' | 'ru' | 'ja' | 'it' | 'ko'] || enDict;

// 1. 动态加载超级产品大字典
const productDict = getProductDictionary(lang);

// 自动匹配方案
const productSlugs = [
  'retractable-telescopic-sunroom',  
  'polycarbonate-carport',
  'stargazing-dome',
  'corner-extended-polycarbonate-canopy',
  'polycarbonate-window-canopy',
  'suspended-polycarbonate-canopy', 
  'inside-corner-canopy',
  'terrace-canopy'
];

const products = productSlugs.map(slug => ({
  slug,
  title: productDict[slug]?.title || "Product",
  image: productDict[slug]?.image || "",
  tags: productDict[slug]?.tags || []
}));

// 通用多语言核心引擎
const t = (groupKey: string, key: string, subKey?: string, tertiaryKey?: string) => {
  const root = currentDict as Record<string, any>;
  const group = root[groupKey] || {};
  
  if (groupKey === 'Footer') {
    if (tertiaryKey) {
      const secondLevel = group[key] || {};
      const thirdLevel = secondLevel[subKey || ''] || {};
      return thirdLevel[tertiaryKey] || tertiaryKey;
    }
    if (subKey) return group[key]?.[subKey] || subKey;
  }

  if (key && !subKey) return group[key] || key;
  if (key && subKey) return group[key]?.[subKey] || subKey;
  
  return root[groupKey] || groupKey;
};

const tHeader = (key: string) => t('Header', key);
const footerDict = (currentDict as any).Footer || {};

// 🌟 核心改进：注入智能多语言保底假数据，防止在开发环境下因为加载延迟导致页脚显示 Loading feeds...
const allBlogPosts = getPostsByLang(lang) || [];

const defaultPosts = [
  {
    slug: '3mm-solid-polycarbonate-sheet-canopy-roofing',
    title: lang === 'zh' ? '3mm实心聚碳酸酯板雨棚屋顶安装指南' : lang === 'ar' ? 'دليل تركيب سقف مظلة ألواح البولي كربونيت المصمتة 3 مم' : '3mm Solid Polycarbonate Sheet Canopy Roofing Installation Guide',
    coverImage: 'https://img.polycanopy.com/2026/02/Large-commercial-polycarbonate-canopy-over-building-entrance.jpg'
  },
  {
    slug: 'securing-your-structure-a-guide-to-anchoring-systems-for-high-wind-areas',
    title: lang === 'zh' ? '确保结构稳固：强风地区锚固系统指南' : lang === 'ar' ? 'تأمين الهيكل: دليل أنظمة التثبيت للمناطق ذات الرياح القوية' : 'Securing Your Structure: Anchoring Systems for High-Wind Areas',
    coverImage: 'https://img.polycanopy.com/2025/12/professional-installation-of-a-polycarbonate-canopy-anchoring-system-in-a-high-wind-coastal-area.webp'
  }
];

// 如果大 JSON 里没有读取到数据，就直接使用保底的优质大厂文章数据进行动态洗牌
const sourcePosts = allBlogPosts.length > 0 ? allBlogPosts : defaultPosts;

const footerRandomPosts = [...sourcePosts]
  .sort(() => 0.5 - Math.random())
  .slice(0, 2)
  .map(p => ({
    slug: p.slug || '',
    title: p.title || '',
    coverImage: p.coverImage || 'https://img.polycanopy.com/default-blog.jpg'
  }));

// ProductSpecs 静态化拆解
const specsSource = (currentDict as any).ProductSpecs || {};
const specsTitle = specsSource.title || "Product Specifications";
const formattedSpecs = [
  { id: 1, title: specsSource.spec1Title || "Customization", desc: specsSource.spec1Desc || "Made to order" },
  { id: 2, title: specsSource.spec2Title || "Origin", desc: specsSource.spec2Desc || "Made in China" },
  { id: 3, title: specsSource.spec3Title || "Warranty", desc: specsSource.spec4Desc || "Long service life" },
  { id: 4, title: specsSource.spec4Title || "Frame Material", desc: specsSource.spec4Desc || "Premium aluminum alloy" },
];

// 材质与剖析解包
const matSource = (currentDict as any).MaterialIntro || {};
const paSource = (currentDict as any).ProductAnalysis || {};
const pfSource = (currentDict as any).ProductFeatures || {};
const pmSource = (currentDict as any).PremiumMaterials || {};
const cuSource = (currentDict as any).ChooseUs || {};

const feat7Sub1 = pfSource.feat7Sub1 || "";
const feat7Sub2 = pfSource.feat7Sub2 || "";
const feat7ExtraText = feat7Sub1 && feat7Sub2 ? `\n\n${feat7Sub1}   ${feat7Sub2}` : "";

const formattedFeatures = [
  { id: 1, title: pfSource.feat1Title || "High impact resistance", desc: pfSource.feat1Desc || "", images: [{ src: "https://img.polycanopy.com/2025/07/High-strength-polycarbonate-panel-with-200x-the-impact-resistance-of-regular-glass.jpg", width: "674", height: "622", alt: pfSource.feat1Alt || "Impact test" }] },
  { id: 2, title: pfSource.feat2Title || "Highly Flexible, Strong and Versatile", desc: pfSource.feat2Desc || "", images: [{ src: "https://img.polycanopy.com/2025/07/Highly-flexible-polycarbonate-sheet-that-bends-easily-without-breaking-ideal-for-canopy-and-shading-applications.jpg", width: "750", height: "750", alt: pfSource.feat2Alt || "Flexibility test" }] },
  { id: 3, title: pfSource.feat3Title || "Fire resistant", desc: pfSource.feat3Desc || "", images: [{ src: "https://img.polycanopy.com/2025/07/fire-resistant-for-canopy.jpg", width: "403", height: "296", alt: pfSource.feat3Alt || "Fire test" }] },
  { id: 4, title: pfSource.feat4Title || "High-Efficiency UV Protection", desc: pfSource.feat4Desc || "", images: [{ src: "https://img.polycanopy.com/2025/07/UV-production.jpg", width: "625", height: "514", alt: pfSource.feat4Alt || "UV protection showcase" }] },
  { id: 5, title: pfSource.feat5Title || "Independent Drainage System", desc: pfSource.feat5Desc || "", images: [
      { src: "https://img.polycanopy.com/2025/07/an-extended-downspout-and-an-enlarged-water-trough.jpg", width: "800", height: "400", alt: pfSource.feat5Alt || "Drainage detail 1" },
      { src: "https://img.polycanopy.com/2025/07/Independent-Drainage-System.jpg", width: "790", height: "831", alt: pfSource.feat5Alt || "Drainage detail 2" }
  ]},
  { id: 6, title: pfSource.feat7Title || "High-strength aluminum alloy profiles", desc: (pfSource.feat7Desc || "") + feat7ExtraText, images: [
      { src: "https://img.polycanopy.com/2025/07/Sturdy-and-Durable-Polycarbonate-Canopy-with-Reinforced-Aluminum-Alloy-Frame.jpg", width: "725", height: "656", alt: pfSource.feat7Alt || "Sturdy frame" },
      { src: "https://img.polycanopy.com/2025/07/Snow-Resistant-Canopy-Installed-in-Cold-Climate-with-Close-up-of-Aluminum-Alloy-Structure.jpg", width: "800", height: "400", alt: pfSource.feat7Alt || "Snow resistance" }
  ]},
  { id: 7, title: pfSource.feat8Title || "Easy Installation with Complete Accessories", desc: pfSource.feat8Desc || "", images: [
      { src: "https://img.polycanopy.com/2025/07/Quick-and-Hassle-Free-Installation-of-Full-Length-Polycarbonate-Canopy.jpg", width: "606", height: "284", alt: pfSource.feat8Alt || "Installation detail 1" },
      { src: "https://img.polycanopy.com/2025/07/Easy-Step-by-Step-Installation-with-Minimal-Effort-and-Time.jpg", width: "706", height: "418", alt: pfSource.feat8Alt || "Installation detail 2" }
  ]}
];

const formattedGuarantees = [
  { title: cuSource.g1Title || "International Quality Standards", detail: cuSource.g1Detail || "Complies with international standard" },
  { title: cuSource.g2Title || "German Bayer Materials", detail: cuSource.g2Detail || "Impact Resistant, Soundproof, Heat Insulating, Flame Retardant" },
  { title: cuSource.g3Title || "Guided Measurement & Installation", detail: cuSource.g3Detail || "Direct Measurement, Customization, Delivery, Installation & After-sales Support" },
  { title: cuSource.g4Title || "Worry-Free After-sales Service", detail: cuSource.g4Detail || "Extended Warranty" },
  { title: cuSource.g5Title || "Quality Assurance", detail: cuSource.g5Detail || "" },
];

const commonDict = (currentDict as any).Common || {};

const isRtl = lang === 'ar';
---

<!DOCTYPE html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <style is:global>@import "tailwindcss";</style>
  </head>
  <body class="bg-gray-50 antialiased m-0 p-0 block w-full">
    
    <Header t={tHeader} lang={lang} currentPath={Astro.url.pathname} />
    
    <ProductsHero 
      title={currentDict.ProductsHero?.title || "Polycarbonate Aluminum Canopy Systems"}
      subtitle={currentDict.ProductsHero?.subtitle || "Custom-designed, durable, and beautiful canopy solutions"}
      imageAlt={currentDict.ProductsHero?.imageAlt || "Detailed Dimensions of Polycarbonate Carport"}
      imageTitle={currentDict.ProductsHero?.imageTitle || "Polycarbonate canopy system details"}
    />
    
    <section class="max-w-7xl mx-auto py-16 px-4">
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">
        {currentDict.ProductsHero?.featuredSolutions || "Our Featured Solutions"}
      </h2>
      
      <ProductGrid 
        client:load 
        products={products} 
        lang={lang} 
        viewDetailsText={commonDict.viewDetails || 'View Details'} 
        factoryDirectText={commonDict.factoryDirect || 'Factory Direct'}
      />
    </section>

    <ProductSpecs title={specsTitle} specs={formattedSpecs} />

    <MaterialIntro 
      client:load
      frameHeading={matSource.frameHeading || "Aluminum Alloy Frame"}
      frameDesc={matSource.frameDesc || "High hardness profiles resist typhoons easily."}
      panelHeading={matSource.panelHeading || "Polycarbonate Panels"}
      panelDesc={matSource.panelDesc || "Premium raw materials guaranteed for over 10 years."}
      colorBronze={matSource.color_bronze || "Bronze"}
      colorWhite={matSource.color_white || "White"}
      colorGray={matSource.color_gray || "Gray"}
      colorBlack={matSource.color_black || "Black"}
      colorChampagne={matSource.color_champagne || "Champagne"}
      ariaFrameBtnTemplate={matSource.aria_frame_btn || "Switch frame to {color}"}
      ariaPanelBtnTemplate={matSource.aria_panel_btn || "Switch panel to {color}"}
      altFrameChampagne={matSource.alt_frame_champagne || "Champagne frame finish"}
      altFrameWhite={matSource.alt_frame_white || "White frame finish"}
      altFrameGray={matSource.alt_frame_gray || "Gray frame finish"}
      altFrameCoffee={matSource.alt_frame_coffee || "Coffee frame finish"}
      altPanelBronze={matSource.alt_panel_bronze || "Bronze solid sheet"}
      altPanelWhite={matSource.alt_panel_white || "White translucent sheet"}
      altPanelGray={matSource.alt_panel_gray || "Gray solid sheet"}
      altPanelBlack={matSource.alt_panel_black || "Black tinted sheet"}
      zoomTipFrame={matSource.zoomTipFrame || "🔍 Click to Enlarge"}
      zoomTipPanel={matSource.zoomTipPanel || "🔍 Click to Enlarge"}
    />

    <ProductAnalysis 
      client:load
      sectionTitle={paSource.sectionTitle || "Product Analysis"}
      systemDesc={paSource.systemDesc || "Polycarbonate canopy system includes wall brackets, reinforced center frame, reinforced columns, downpipes, gutters, and various colors of polycarbonate solid panels, diamond particle panels, or raindrop particle panels."}
      whyTitle={paSource.whyTitle || "Why Choose High-Quality Polycarbonate Sheets?"}
      whyDesc1={paSource.whyDesc1 || "In canopy and skylight projects, it’s not the steel frame — it’s the panel that determines longevity. Low-grade sheets can yellow, crack, or leak within a few years, leading to costly replacements."}
      whyDesc2={paSource.whyDesc2 || "Our premium polycarbonate features a single-sided UV co-extruded layer, preserving clarity and durability for over 10 years."}
      whyDesc3={paSource.whyDesc3 || "Choose quality from the start — Save on maintenance and enjoy peace of mind."}
      altSystemImg={paSource.altSystemImg || "Exploded view of canopy structure with labeled components"}
      altCompareImg={paSource.altCompareImg || "Comparison of high-quality and low-quality polycarbonate sheets"}
      zoomTip={matSource.zoomTipFrame || "🔍 Click to Enlarge"}
    />

    <ProductFeatures 
      client:load
      sectionTitle={pfSource.sectionTitle || "Product Features"}
      badge1={pfSource.badge1 || "Corrosion Resistant"}
      badge2={pfSource.badge2 || "Easy Maintenance"}
      badge3={pfSource.badge3 || "Light Transmission"}
      badge4={pfSource.badge4 || "Beautiful Design"}
      badge5={pfSource.badge5 || "Sound Dampening"}
      features={formattedFeatures}
      zoomTip={matSource.zoomTipFrame || "🔍 Click to Enlarge"}
      mainFeatImg="https://img.polycanopy.com/2025/07/polycanopy-product-features-engineered-for-snow-load-resistance-uv-protection-wind-and-rain-defense-and-impact-resistance.jpg"
      mainFeatAlt={pfSource.mainFeatAlt || "Comprehensive product features blueprint"}
      mainFeatZoomTip={pfSource.mainFeatZoomTip || "🔍 Click to view blueprint"}
      subHeading={pfSource.subHeading || "Hardcore Performance & Rigorous Testing"}
      subDesc={pfSource.subDesc || "See how our structures handle extreme real-world challenges"}
      testLabel={pfSource.testLabel || "Performance Test"}
    />

    <ChooseUs 
      client:load
      heading={cuSource.heading || "Choose Us for Peace of Mind"}
      tagline={cuSource.tagline || "A quality canopy makes all the difference"}
      lifespanLabel={cuSource.lifespanLabel || "Normal Service Life: 30 Years"}
      lifespanValue={cuSource.lifespanValue || "Truly Worth It"}
      guarantees={formattedGuarantees}
    />

    <PremiumMaterials 
      client:load
      title={pmSource.title || "Quality Materials Make All the Difference"}
      desc={pmSource.desc || "Aerospace-grade titanium-magnesium aluminum alloy with advanced coating technology..."}
      mat1Label={pmSource.mat1Label || "High-strength aluminum alloy"}
      mat2Label={pmSource.mat2Label || "German Bayer polycarbonate sheet"}
      imgSrc="https://img.polycanopy.com/2025/07/Aerospace-Grade-Aluminum-Alloy-and-German-Bayer-Polycarbonate.jpg"
      imgAlt={pmSource.imgAlt || "Aerospace-Grade Aluminum Alloy and German Bayer Polycarbonate materials overview"}
      zoomTip={matSource.zoomTipFrame || "🔍 Click to Enlarge"}
    />
    
    <Footer client:visible dict={footerDict} lang={lang} latestPosts={footerRandomPosts} />
    
  </body>
</html>