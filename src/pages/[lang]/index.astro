---
import Header from '../../components/Header';
import Hero from '../../components/home/Hero';
import About from '../../components/home/About';
import WhyChoose from '../../components/home/WhyChoose';
import ProductRange from '../../components/home/ProductRange';
import Features from '../../components/home/Features';
import CustomService from '../../components/home/CustomService';
import Specs from '../../components/home/Specs';
import Gallery from '../../components/home/Gallery';
import Testimonials from '../../components/home/Testimonials';
import Faq from '../../components/home/Faq.tsx';
import Footer from '../../components/Footer';
import { getPostsByLang } from '../../utils/blogLoader'; // 🌟 引入博客数据源用于页脚随机推荐

import enDict from '../../i18n/en.json';
import zhDict from '../../i18n/zh.json';
import arDict from '../../i18n/ar.json';
import deDict from '../../i18n/de.json';
import esDict from '../../i18n/es.json';
import ptDict from '../../i18n/pt.json';
import frDict from '../../i18n/fr.json';
import ruDict from '../../i18n/ru.json';
import jaDict from '../../i18n/ja.json';
import itDict from '../../i18n/it.json';
import koDict from '../../i18n/ko.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'ar' } },
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ru' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'it' } },
    { params: { lang: 'ko' } },
  ];
}

const { lang } = Astro.params;

// ✅ 换用 Record<string, any> 宽松高兼容类型，彻底消除类型对不齐红线
const dictionaries: Record<string, any> = {
  en: enDict, zh: zhDict, ar: arDict, de: deDict, es: esDict,
  pt: ptDict, fr: frDict, ru: ruDict, ja: jaDict, it: itDict, ko: koDict
};

// ✅ 使用 11 国强势类型断言，彻底封杀 TypeScript 编译红线
const currentDict = dictionaries[lang as 'en' | 'zh' | 'ar' | 'de' | 'es' | 'pt' | 'fr' | 'ru' | 'ja' | 'it' | 'ko'] || enDict;

// 全局普通双层/三层多语言提取通用引擎
const t = (groupKey: string, key: string, subKey?: string, tertiaryKey?: string) => {
  const root = currentDict as Record<string, any>;
  const group = root[groupKey] || {};
  
  if (groupKey === 'WhyChoose' && subKey) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey] || subKey;
  }

  if (groupKey === 'ProductRange' && key) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey || ''] || subKey || '';
  }

  if (groupKey === 'Features' && subKey) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey] || subKey;
  }
  
  if (groupKey === 'CustomService' && key === 'items' && subKey) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[subKey] || subKey;
  }

  if (groupKey === 'Specs' && subKey) {
    const dataGroup = group['data'] || {};
    return dataGroup[key]?.[subKey] || subKey;
  }

  if (groupKey === 'Gallery' && subKey) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey] || subKey;
  }

  if (groupKey === 'Testimonials' && subKey) {
    if (key === 'global') return group[subKey] || subKey;
    const reviewsGroup = group['reviews'] || {};
    return reviewsGroup[key]?.[subKey] || subKey;
  }

  if (groupKey === 'Footer') {
    if (tertiaryKey) {
      const secondLevel = group[key] || {};
      const thirdLevel = secondLevel[subKey || ''] || {};
      return thirdLevel[tertiaryKey] || tertiaryKey;
    }
    if (subKey) return group[key]?.[subKey] || subKey;
  }

  if (key && !subKey) return group[key] || key;
  if (key && subKey) return group[key]?.[subKey] || subKey;
  
  return root[groupKey] || groupKey;
};

// 安全解包 FAQ 静态数组
const faqSourceData = currentDict.Faq || {};
const faqTitle = faqSourceData.title || "Frequently Asked Questions";
const faqSubtitle = faqSourceData.subtitle || "Everything you need to know about our polycarbonate canopies";
const faqQuestionsArray = faqSourceData.questions || [];

const tHeader = (key: string) => t('Header', key);
const tHero = (key: string) => t('Hero', key);
const tAbout = (key: string) => t('About', key);
const tWhyChoose = (key: string, subKey?: string) => t('WhyChoose', key, subKey);
const tProductRange = (key: string, subKey?: string) => t('ProductRange', key, subKey);
const tFeatures = (key: string, subKey?: string) => t('Features', key, subKey);
const tCustomService = (key: string, subKey?: string) => t('CustomService', key, subKey);
const tSpecs = (key: string, subKey?: string) => t('Specs', key, subKey);
const tGallery = (key: string, subKey?: string) => t('Gallery', key, subKey);
const tTestimonials = (key: string, subKey?: string) => t('Testimonials', key, subKey);
const footerDict = (currentDict as any).Footer || {};

// 🌟 动态页脚文章洗牌引擎
const allBlogPosts = getPostsByLang(lang) || [];
const footerRandomPosts = [...allBlogPosts]
  .sort(() => 0.5 - Math.random())
  .slice(0, 2)
  .map(p => ({
    slug: p.slug || '',
    title: p.title || '',
    coverImage: p.coverImage || 'https://img.polycanopy.com/default-blog.jpg'
  }));

const isRtl = lang === 'ar';

// 🌟 11国地道 locale 映射池，用于增强大厂建材站的 OpenGraph 权重
const localeMapping: Record<string, string> = { 
  en: 'en_US', zh: 'zh_CN', ar: 'ar_AR', de: 'de_DE', es: 'es_MX',
  pt: 'pt_BR', fr: 'fr_FR', ru: 'ru_RU', ja: 'ja_JP', it: 'it_IT', ko: 'ko_KR'
};
const currentLocale = localeMapping[lang] || 'en_US';
import Layout from '../../layouts/Layout.astro';
---

<Layout title={`${tHero('titlePrefix')}${tHero('titleHighlight')}${tHero('titleSuffix')}`} lang={lang}>
    
  <Header t={tHeader} lang={lang} currentPath={Astro.url.pathname} />
  
  <Hero t={tHero} lang={lang} />
  
  <About t={tAbout} />
  <WhyChoose t={tWhyChoose} lang={lang} />
  
  <ProductRange t={tProductRange} lang={lang} />

  <Features t={tFeatures} />
  <CustomService t={tCustomService} />
  <Specs t={tSpecs} lang={lang} />
  <Gallery t={tGallery} lang={lang} />
  <Testimonials t={tTestimonials} />

  <Faq title={faqTitle} subtitle={faqSubtitle} items={faqQuestionsArray} client:load />

  <Footer client:visible dict={footerDict} lang={lang} latestPosts={footerRandomPosts} />
    
</Layout>