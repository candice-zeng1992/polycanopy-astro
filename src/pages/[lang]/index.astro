---
// src/pages/[lang]/index.astro
import Header from '../../components/Header';
import Hero from '../../components/home/Hero';
import About from '../../components/home/About';
import ProductRange from '../../components/home/ProductRange';
import Features from '../../components/home/Features'; // 🌟 1. 引入我们的 Features 组件
import Footer from '../../components/Footer';

import enDict from '../../i18n/en.json';
import zhDict from '../../i18n/zh.json';
import arDict from '../../i18n/ar.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang } = Astro.params;

const dictionaries: Record<'en' | 'zh' | 'ar', typeof enDict> = {
  en: enDict,
  zh: zhDict,
  ar: arDict,
};

const currentDict = dictionaries[lang as keyof typeof dictionaries] || enDict;

// 🌟 全局无死角翻译提取函数：支持所有板块的深度多级嵌套结构
const t = (groupKey: string, key: string, subKey?: string, tertiaryKey?: string) => {
  const root = currentDict as Record<string, any>;
  const group = root[groupKey] || {};
  
  // A. 适配 ProductRange 的 items 四层嵌套
  if (groupKey === 'ProductRange' && key) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey || ''] || subKey || '';
  }

  // B. 🌟 适配 Features 的 items 三层嵌套处理
  if (groupKey === 'Features' && subKey) {
    const itemsGroup = group['items'] || {};
    return itemsGroup[key]?.[subKey] || subKey;
  }
  
  // C. 适配 Footer 的 form.options 等深度嵌套
  if (groupKey === 'Footer') {
    if (tertiaryKey) {
      const secondLevel = group[key] || {};
      const thirdLevel = secondLevel[subKey || ''] || {};
      return thirdLevel[tertiaryKey] || tertiaryKey;
    }
    if (subKey) {
      return group[key]?.[subKey] || subKey;
    }
  }

  // D. 常规双层节点处理
  if (key && !subKey) {
    return group[key] || key;
  }
  if (key && subKey) {
    return group[key]?.[subKey] || subKey;
  }
  
  return root[groupKey] || groupKey;
};

// 快捷绑定各大板块的专属翻译偏函数
const tHeader = (key: string) => t('Header', key);
const tHero = (key: string) => t('Hero', key);
const tAbout = (key: string) => t('About', key);
const tProductRange = (key: string, subKey?: string) => t('ProductRange', key, subKey);
const tFeatures = (key: string, subKey?: string) => t('Features', key, subKey); // 🌟 2. 绑定 Features 偏函数
const tFooter = (key: string, subKey?: string, tertiaryKey?: string) => t('Footer', key, subKey, tertiaryKey);

const isRtl = lang === 'ar';
---

<!DOCTYPE html>
<html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tHero('titlePrefix')}{tHero('titleHighlight')}{tHero('titleSuffix')}</title>
    
    <style is:global>
      @import "tailwindcss";
    </style>
  </head>
  <body class="bg-gray-50 antialiased m-0 p-0">
    
    {/* 顶层透明悬浮页眉 */}
    <Header t={tHeader} lang={lang} />
    
    {/* 顶层巨幕 */}
    <Hero t={tHero} lang={lang} />
    
    {/* 品牌关于模块 */}
    <About t={tAbout} />
    
    {/* 产品系列八宫格 */}
    <ProductRange t={tProductRange} lang={lang} />

    {/* 🌟 3. 完美拼接：四大核心特性网格震撼登场！无缝衔接在 ProductRange 下方 */}
    <Features t={tFeatures} />
    
    {/* 询盘大页脚 */}
    <Footer t={tFooter} lang={lang} />
    
  </body>
</html>