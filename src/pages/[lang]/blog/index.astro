---
import Header from '../../../components/Header';
import Footer from '../../../components/Footer';
import { getPostsByLang } from '../../../utils/blogLoader';
import { getProductDictionary } from '../../../i18n';

import enDict from '../../../i18n/en.json';
import zhDict from '../../../i18n/zh.json';
import arDict from '../../../i18n/ar.json';
import deDict from '../../../i18n/de.json';
import esDict from '../../../i18n/es.json';
import ptDict from '../../../i18n/pt.json';
import frDict from '../../../i18n/fr.json';
import ruDict from '../../../i18n/ru.json';
import jaDict from '../../../i18n/ja.json';
import itDict from '../../../i18n/it.json';
import koDict from '../../../i18n/ko.json';

interface Post {
  id: string;
  lang: string;
  title: string;
  slug: string;
  seoTitle?: string;
  seoDesc?: string;
  publishedAt: string;
  author: string;
  coverImage: string;
  category: string;
  excerpt?: string;
  contentHtml: string;
}

const dictionaries = {
  en: enDict,
  zh: zhDict,
  ar: arDict,
  de: deDict,
  es: esDict,
  pt: ptDict,
  fr: frDict,
  ru: ruDict,
  ja: jaDict,
  it: itDict,
  ko: koDict,
};

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'ar' } },
    { params: { lang: 'de' } },
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'ru' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'it' } },
    { params: { lang: 'ko' } },
  ];
}

const { lang } = Astro.params;

const posts: Post[] = getPostsByLang(lang)
  .sort((a: Post, b: Post) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const currentDict = dictionaries[lang as keyof typeof dictionaries] || enDict;

const tHeader = (key: string) => {
  const root = currentDict as Record<string, any>;
  const group = root['Header'] || {};
  return group[key] || key;
};

const footerDict = (currentDict as any).Footer || {};

const pageLabels = {
  metaTitle: (currentDict as any).Blog?.metaTitle || 'Blog & Insights - PolyCanopy',
  metaDesc: (currentDict as any).Blog?.metaDesc || 'Explore our latest articles.',
  heroTitle: (currentDict as any).Blog?.heroTitle || 'Knowledge Base & Insights',
  heroSub: (currentDict as any).Blog?.heroSub || 'Professional guides and technical analyses.',
  readMore: (currentDict as any).Blog?.readMore || (lang === 'zh' ? '阅读全文 →' : lang === 'ar' ? 'قراءة المقال كاملاً ←' : 'Read Full Article →'),
  noPosts: (currentDict as any).Blog?.noPosts || (lang === 'zh' ? '该语言下暂无发布文章。' : lang === 'ar' ? 'لم يتم العثور على مقالات' : 'No articles found under this language.')
};

const localeFormat = (currentDict as any).Blog?.dateFormat || (lang === 'zh' ? 'zh-CN' : lang === 'ar' ? 'ar-SA' : 'en-US');

const productDict = getProductDictionary(lang);
const productSlugs = [
  'retractable-telescopic-sunroom',
  'polycarbonate-carport',
  'stargazing-dome',
  'corner-extended-polycarbonate-canopy',
  'polycarbonate-window-canopy',
  'suspended-polycarbonate-canopy',
  'inside-corner-canopy',
  'terrace-canopy'
];

const products = productSlugs.map(slug => ({
  slug,
  title: productDict[slug]?.title || "Product",
  image: productDict[slug]?.image || "",
  tags: productDict[slug]?.tags || []
}));

const viewDetailsText = currentDict.ProductsHero?.viewDetails || (lang === 'zh' ? '查看详情' : lang === 'ar' ? 'عرض التفاصيل' : 'View Details');
const isRtl = lang === 'ar';
---
<!DOCTYPE html><html lang={lang} dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{pageLabels.metaTitle}</title>
    <meta name="description" content={pageLabels.metaDesc} />
    <style is:global>@import "tailwindcss";</style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  </head>
  <body class="bg-slate-50 antialiased m-0 p-0 block w-full">
    <Header t={tHeader} lang={lang} currentPath={Astro.url.pathname} />
    
    <section class="relative w-full h-[40vh] min-h-[320px] max-h-[480px] flex items-center justify-center bg-slate-900 overflow-hidden">
      <img
        src="https://img.polycanopy.com/2025/07/Modern-Blue-Polycarbonate-Canopy-with-White-Aluminum-Frame-Under-Clear-Sky.jpg"
        alt={(currentDict as any).Blog?.heroAlt || 'Polycarbonate Canopy'}
        class="absolute inset-0 w-full h-full object-cover scale-100"
      />
      <div class="absolute inset-0 bg-black/40 bg-gradient-to-b from-black/50 via-transparent to-black/30" />
      <div class="relative max-w-4xl mx-auto px-4 z-10 text-center mt-12">
        <h1 class="text-3xl md:text-5xl font-black text-white tracking-tight mb-4 drop-shadow-sm">
          {pageLabels.heroTitle}
        </h1>
        <p class="text-sm md:text-base text-slate-100 max-w-2xl mx-auto font-medium leading-relaxed drop-shadow-sm">
          {pageLabels.heroSub}
        </p>
      </div>
    </section>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      {posts.length === 0 ? (
        <div class="text-center py-20 bg-white rounded-3xl border border-slate-100 shadow-sm">
          <p class="text-gray-400 font-medium">{pageLabels.noPosts}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
          {posts.map((postItem) => {
            const postDate = new Date(postItem.publishedAt).toLocaleDateString(
              localeFormat,
              { year: 'numeric', month: 'short', day: 'numeric' }
            );
            return (
              <article class="group flex flex-col bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300">
                <a href={`/${lang}/blog/${postItem.slug}`} class="block relative aspect-video overflow-hidden bg-slate-100 shrink-0">
                  <img src={postItem.coverImage} alt={postItem.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  <span class={`absolute bottom-3 ${isRtl ? 'right-3' : 'left-3'} inline-block bg-slate-900/80 backdrop-blur-md text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider`}>
                    {postItem.category}
                  </span>
                </a>
                <div class="flex-1 p-6 flex flex-col">
                  <div class="flex items-center gap-3 text-xs text-slate-400 mb-3 font-medium">
                    <span class="text-slate-700 font-semibold">{postItem.author}</span>
                    <span>•</span>
                    <time datetime={postItem.publishedAt}>{postDate}</time>
                  </div>
                  <h2 class="text-lg font-bold text-slate-900 leading-snug mb-3 group-hover:text-blue-600 transition-colors line-clamp-2">
                    <a href={`/${lang}/blog/${postItem.slug}`}>{postItem.title}</a>
                  </h2>
                  <p class="text-sm text-slate-500 line-clamp-2 leading-relaxed mb-6 flex-1">
                    {postItem.excerpt || postItem.seoDesc}
                  </p>
                  <div class="pt-4 border-t border-slate-50">
                    <a href={`/${lang}/blog/${postItem.slug}`} class="inline-flex items-center text-xs font-bold text-blue-600 group-hover:text-blue-700 transition-colors gap-1">
                      {pageLabels.readMore}
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </main>

    <section class="w-full bg-white border-t border-slate-100 py-16 md:py-24 shadow-inner overflow-hidden">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mb-3">
            {currentDict.ProductsHero?.featuredSolutions || (lang === 'zh' ? '工厂核心主推产品' : lang === 'ar' ? 'منتجاتنا الرئيسية' : 'Featured Architectural Solutions')}
          </h2>
          <p class="text-sm text-slate-500 font-medium">
            {lang === 'zh' ? '直连制造基地，专为高抗冲击与持久采光性能打造的工业级解决方案。' : 'High-performance manufacturing engineered for global structural resilience.'}
          </p>
        </div>
        <div class="swiper product-swiper !pb-14 !px-2">
          <div class="swiper-wrapper">
            {products.map((product) => (
              <div class="swiper-slide h-auto">
                <a href={`/${lang}/products/${product.slug}`} class="group block h-full bg-white rounded-xl shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden border border-gray-100">
                  <div class="aspect-[4/3] overflow-hidden bg-gray-50 relative">
                    <img src={product.image} alt={product.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    <div class="absolute top-3 left-3 bg-[#184e77]/90 text-white text-[10px] uppercase font-bold tracking-widest px-2 py-0.5 rounded shadow-xs">Factory Direct</div>
                  </div>
                  <div class="p-6 flex flex-col justify-between min-h-[180px]">
                    <div>
                      <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-[#12b886] transition-colors line-clamp-2">{product.title}</h3>
                      <div class="flex flex-wrap gap-2 mb-6">
                        {product.tags && product.tags.map((tag: string) => (
                          <span class="text-xs font-semibold bg-[#12b886]/10 text-[#12b886] px-3 py-1 rounded-full uppercase tracking-wider transition-colors group-hover:bg-[#12b886] group-hover:text-white">{tag}</span>
                        ))}
                      </div>
                    </div>
                    <div class="flex items-center text-[#184e77] font-bold text-sm group-hover:text-[#12b886] transition-all">
                      <span class="group-hover:mr-1 transition-all">{viewDetailsText}</span>
                      <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                      </svg>
                    </div>
                  </div>
                </a>
              </div>
            ))}
          </div>
          <div class="swiper-pagination"></div>
        </div>
      </div>
    </section>

    <Footer client:visible dict={footerDict} lang={lang} />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script is:inline define:vars={{ isRtl }}>
      new Swiper('.product-swiper', {
        slidesPerView: 1,
        spaceBetween: 24,
        loop: true,
        autoplay: { delay: 4500, disableOnInteraction: false },
        pagination: { el: '.swiper-pagination', clickable: true },
        rtl: isRtl,
        breakpoints: {
          640: { slidesPerView: 2, spaceBetween: 24 },
          1024: { slidesPerView: 3, spaceBetween: 32 }
        }
      });
    </script>
  </body>
</html>
<style is:global>
  .product-swiper .swiper-pagination-bullet-active {
    background: #184e77 !important;
    width: 24px !important;
    border-radius: 4px !important;
    transition: all 0.3s ease;
  }
</style>